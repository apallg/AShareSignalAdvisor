# Apallg投研 - 环境变量配置示例（复制为 .env 并填入实际值）

# LLM 配置（DeepSeek 或 通义千问）
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
# QWEN_API_KEY=sk-your_qwen_api_key_here

# MySQL 数据库
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=qilin_stock

# Coze 通知（可选）
COZE_API_TOKEN=
COZE_BOT_ID=
COZE_WORKFLOW_ID=

# QMT / miniQMT 交易配置（可选，默认使用 FakeBroker 模拟交易）
# BROKER_TYPE=qmt                      # "fake" | "qmt"
# QMT_USERDATA_DIR=D:\迅投极速交易终端 睿智融科版\userdata_mini
# QMT_ACCOUNT=你的资金账号
# QMT_SESSION_ID=123456
