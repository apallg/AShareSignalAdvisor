# Apallg投研 - 环境变量配置示例（复制为 .env 并填入实际值）

# LLM 配置（DeepSeek 或 通义千问）
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
# QWEN_API_KEY=sk-your_qwen_api_key_here

# MySQL 数据库
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=qilin_stock

# 企业微信机器人通知（推荐，群机器人 webhook）
# 在企业微信群中添加机器人，复制 webhook 地址中 key= 后面的部分
WECOM_BOT_KEY=

# Coze 通知（备用）
COZE_API_TOKEN=
COZE_BOT_ID=
COZE_WORKFLOW_ID=

# 交易日定时扫描（早盘/尾盘全量扫描，阈值默认7）
# SCAN_MORNING_TIME=09:35
# SCAN_AFTERNOON_TIME=14:55
# SCAN_DEFAULT_THRESHOLD=7

# QMT / miniQMT 交易配置（可选，默认使用 FakeBroker 模拟交易）
# BROKER_TYPE=qmt                      # "fake" | "qmt"
# QMT_USERDATA_DIR=D:\迅投极速交易终端 睿智融科版\userdata_mini
# QMT_ACCOUNT=你的资金账号
# QMT_SESSION_ID=123456

# easytrader 同花顺客户端交易（银河证券等，不需要券商 API 权限）
# BROKER_TYPE=easytrader               # "fake" | "qmt" | "easytrader"
# EASYTRAIDER_USER=你的同花顺账号
# EASYTRAIDER_PASSWORD=你的同花顺密码
# EASYTRAIDER_EXE_PATH=C:\双子星-中国银河证券\Binarystar.exe

# 收盘前强制平仓（默认开启，14:54 后自动清仓）
# FORCE_CLOSE_ENABLED=true
# FORCE_CLOSE_TIME=14:54
# FORCE_CLOSE_REASON=收盘前强制平仓
# TRADING_IDLE_INTERVAL=300             # 非交易时段休眠间隔(秒)

# 多指标信号融合投票（默认关闭）
# SIGNAL_FUSION_ENABLED=false
# SIGNAL_FUSION_MODE=filter             # "filter" 过滤模式 | "override" 覆写模式
# SIGNAL_FUSION_MIN_CONFIDENCE=0.6      # 最小置信度阈值
# SIGNAL_FUSION_WEIGHT_MACD=1.0
# SIGNAL_FUSION_WEIGHT_RSI=0.8
# SIGNAL_FUSION_WEIGHT_MA=0.7
# SIGNAL_FUSION_WEIGHT_KDJ=0.5
# SIGNAL_FUSION_WEIGHT_BB=0.6
# SIGNAL_FUSION_WEIGHT_VOLUME=0.3
